
.header-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20rpx;
  }

.header-actions {
    display: flex;
    align-items: center;
    gap: 16rpx;
  }
  
.history-page {
    padding: 30rpx;
    background-color: #FFFDF7;
  }

.migrate-button {
    padding: 10rpx 24rpx;
    border-radius: 999rpx;
    font-size: 24rpx;
    color: #ffffff;
    background: linear-gradient(135deg, #86a8ff 0%, #6b78ff 100%);
  }

.tag-row {
  margin-top: 10rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag-item {
  font-size: 22rpx;
  color: #4f5cbf;
  background: rgba(140, 156, 255, 0.16);
  border: 1px solid rgba(140, 156, 255, 0.35);
  border-radius: 999rpx;
  padding: 4rpx 14rpx;
}
  
.add-button {
    font-size: 40rpx;
    font-weight: bold;
    color: #D8B4A0;
    padding: 0 20rpx;
  }

  .section-title {
    font-size: 36rpx;
    font-weight: 700;
    color: #A8D5BA;
    margin-bottom: 20rpx;
  }

.section-subtitle {
    margin-top: -8rpx;
    font-size: 22rpx;
    color: #94a2c9;
  }

.star-icon {
    position: absolute;
    top: 16rpx;
    right: 16rpx;
    font-size: 32rpx;
    color: #FFD700;
    z-index: 10;
  }

.sync-state {
    margin-top: 12rpx;
    font-size: 22rpx;
    color: #8a95b8;
  }
  
  