.page {
  min-height: 100vh;
  background: #f5f7ff;
  padding: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(42, 61, 120, 0.08);
  margin-bottom: 20rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2b3562;
  margin-bottom: 16rpx;
}

.form-row {
  margin-bottom: 14rpx;
}

.label {
  display: block;
  margin-bottom: 6rpx;
  font-size: 24rpx;
  color: #5b6693;
}

.input,
.picker {
  width: 100%;
  min-height: 68rpx;
  border-radius: 12rpx;
  border: 1px solid #d7ddf6;
  background: #f9faff;
  padding: 16rpx;
  font-size: 26rpx;
  color: #2b3562;
  box-sizing: border-box;
}

.primary {
  margin-top: 14rpx;
  background: linear-gradient(135deg, #5e6dff 0%, #6f42df 100%);
  color: #fff;
  border-radius: 999rpx;
}

.secondary {
  background: #eef0ff;
  color: #5e6dff;
  border-radius: 999rpx;
  font-size: 26rpx;
  margin-top: 8rpx;
}

.loading,
.empty {
  text-align: center;
  padding: 40rpx 0;
  color: #8791b3;
  font-size: 26rpx;
}

.checklist-header {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-bottom: 14rpx;
}

.checklist-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.expand-icon {
  font-size: 24rpx;
  color: #8791b3;
  padding: 0 12rpx;
}

.meta-actions {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.edit-btn {
  color: #5e6dff;
  font-size: 24rpx;
  padding: 6rpx 12rpx;
}

.toolbar {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 14rpx;
}

.toggle-show-done {
  background: #eef0ff;
  color: #5e6dff;
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
}

.checklist-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #253162;
}

.checklist-title.all-done {
  color: #20a779;
  text-decoration: line-through;
}

.owner-tag {
  font-size: 22rpx;
  color: #8791b3;
  font-weight: 400;
  margin-left: 8rpx;
}

.checklist-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12rpx;
}

.date-chip {
  display: inline-block;
  background: #eef0ff;
  color: #5e6dff;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
}

.delete-btn {
  color: #c0392b;
  font-size: 24rpx;
  padding: 6rpx 12rpx;
}

.progress-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.progress-bar {
  flex: 1;
  height: 12rpx;
  background: #e9ecff;
  border-radius: 999rpx;
  overflow: hidden;
}

.progress-inner {
  height: 100%;
  background: linear-gradient(135deg, #5e6dff 0%, #6f42df 100%);
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 22rpx;
  color: #5b6693;
  min-width: 260rpx;
  text-align: right;
}

.items {
  margin-bottom: 16rpx;
}

.item {
  padding: 16rpx;
  border: 1px solid #e5e9ff;
  border-radius: 14rpx;
  background: #fbfcff;
  margin-bottom: 12rpx;
}

.item.item-done {
  background: #f0fcf5;
  border-color: #b7e4c7;
}

.item-main {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border-radius: 10rpx;
  border: 2rpx solid #c4cbed;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.checkbox.checked {
  background: #20a779;
  border-color: #20a779;
}

.item-body {
  flex: 1;
  min-width: 0;
}

.item-content {
  font-size: 28rpx;
  color: #253162;
  font-weight: 500;
  word-break: break-all;
}

.item-done .item-content {
  color: #8791b3;
  text-decoration: line-through;
}

.item-blocker {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #d97706;
  word-break: break-all;
}

.blocker-placeholder {
  color: #a4abc9;
  font-size: 22rpx;
}

.item-delete {
  color: #c0392b;
  font-size: 32rpx;
  padding: 0 10rpx;
  flex-shrink: 0;
}

.add-item-row {
  border-top: 1rpx dashed #d7ddf6;
  padding-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.item-input {
  margin-bottom: 0;
}
