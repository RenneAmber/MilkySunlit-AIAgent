.delete-button {
    font-size: 24rpx;
    color: #D9534F;
    text-align: right;
    margin-top: 10rpx;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: scale(0.8); }
    to { opacity: 1; transform: scale(1); }
  }
  
  .diary-card {
    position: relative;
  }
  

  .delete-icon {
    position: absolute;
    bottom: 16rpx;
    right: 16rpx;
    font-size: 32rpx;
    color: #D9534F;
    background-color: #fff;
    border-radius: 50%;
    padding: 10rpx;
    box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
    animation: fadeIn 0.4s ease-in-out;
    z-index: 10;
    transition: background-color 0.3s ease;
  }

    
  .diary-card {
    background-color: #FFF;
    border-radius: 12rpx;
    box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
    margin-bottom: 30rpx;
    padding: 20rpx;
  }

  
.diary-image {
    width: 100%;
    height: 200rpx; /* 固定高度，可根据需要调整 */
    object-fit: contain;
    background-color: #f8f8f8; /* 可选：给图片加个背景色避免空白 */
  }

  .diary-text {
    margin-top: 16rpx;
    font-size: 28rpx;
    color: #333;
  }

  .diary-meta {
    display: flex;
    justify-content: space-between;
    margin-top: 10rpx;
    font-size: 24rpx;
    color: #D8B4A0;
  }